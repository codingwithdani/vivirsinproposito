{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "vivirsinproposito.com" }],
      "destination": "https://www.malaveautor.com/vivir-sin-proposito",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.vivirsinproposito.com" }],
      "destination": "https://www.malaveautor.com/vivir-sin-proposito",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css|woff2|woff|ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|webp|png|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
